{
  "name": "foxglove-py-trees-viewer",
  "displayName": "Foxglove PyTrees Viewer",
  "description": "A Foxglove Studio extension for visualizing ROS 2 PyTrees behavior trees, featuring interactive pan/zoom, live status updates, feedback message display, and success-state latching.",
  "publisher": "mcgill-robotics",
  "homepage": "https://github.com/mcgill-robotics/foxglove-py-trees-viewer",
  "version": "1.0.1",
  "license": "MIT",
  "main": "./dist/extension.js",
  "keywords": ["foxglove", "ros2", "pytrees", "behavior-tree", "robotics"],
  "scripts": {
    "build": "foxglove-extension build",
    "foxglove:prepublish": "foxglove-extension build --mode production",
    "lint": "eslint .",
    "lint:ci": "eslint .",
    "lint:fix": "eslint --fix .",
    "local-install": "foxglove-extension install",
    "package": "foxglove-extension package",
    "publish-org": "npm run package && foxglove extensions publish ./mcgill-robotics.foxglove-py-trees-viewer-1.0.0.foxe",
    "pretest": "foxglove-extension pretest"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "2.1.2",
    "@foxglove/extension": "2.54.0",
    "@types/dagre": "^0.7.54",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "create-foxglove-extension": "1.3.2",
    "css-loader": "^7.1.4",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "style-loader": "^4.0.0",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "reactflow": "^11.11.4"
  }
}
